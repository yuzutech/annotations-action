{
  "name": "@yuzutech/annotations-action",
  "version": "0.5.0",
  "description": "GitHub action that creates annotations from a JSON file",
  "main": "index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "format": "prettier --write index.js",
    "package": "ncc build index.js -o dist",
    "test": "prettier --check index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuzutech/annotations-action.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript",
    "Annotations"
  ],
  "author": "GitHub",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yuzutech/annotations-action/issues"
  },
  "homepage": "https://github.com/yuzutech/annotations-action#readme",
  "dependencies": {
    "@actions/core": "~3.0",
    "@actions/github": "~9.0"
  },
  "devDependencies": {
    "@vercel/ncc": "0.38.4",
    "prettier": "~3.8"
  },
  "volta": {
    "node": "24.14.1"
  }
}
